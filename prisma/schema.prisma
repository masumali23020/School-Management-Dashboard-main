generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum UserSex {
  MALE
  FEMALE
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

enum PaymentMethod {
  CASH
  MOBILE_BANKING
  BANK_TRANSFER
}

enum UserRole {
  ADMIN
  CASHIER
  TEACHER
  STAFF
}

enum PlanType {
  FREE
  STANDARD
  POPULAR
}

enum SMSStatus {
  SENT
  FAILED
  PENDING
}

enum SubscriptionPaymentStatus {
  PAID
  PENDING
  FAILED
}

// --- SAAS SUPER ADMIN & SUBSCRIPTION ---

model SuperAdmin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model SubscriptionPlan {
  id           Int      @id @default(autoincrement())
  name         PlanType @unique
  price        Decimal  @db.Decimal(10, 2)
  maxStudents  Int      @default(50)
  maxEmployees Int      @default(5)
  hasSMS       Boolean  @default(false)
  hasAnalytics Boolean  @default(false)
  schools      School[]

  @@map("subscription_plan") // maps Prisma model to existing table
}

// --- CORE SCHOOL MODEL (TENANT) ---

model School {
  id              Int     @id @default(autoincrement())
  schoolName      String
  shortName       String?
  slug            String  @unique
  logoUrl         String?
  bannerUrl       String?
  email           String?
  phone           String?
  address         String?
  establishedYear String?
  passRate        String?
  eiinNumber      String? @unique
  academicSession String  @default("2026")

  planId     Int
  plan       SubscriptionPlan @relation(fields: [planId], references: [id])
  isActive   Boolean          @default(true)
  smsBalance Int              @default(0)
  expiredAt  DateTime?

  employees             Employee[]
  students              Student[]
  parents               Parent[]
  grades                Grade[]
  classes               Class[]
  subjects              Subject[]
  homeSliders           HomeSlider[]
  feeTypes              FeeType[]
  salaryTypes           SalaryType[]
  smsLogs               SMSLog[]
  events                Event[]
  announcements         Announcement[]
  assignments           Assignment[]
  exams                 Exam[]
  results               Result[]
  attendance            Attendance[]
  lessons               Lesson[]
  assignmentPublishes   AssignmentPublish[]
  examPublishes         ExamPublish[]
  studentClassHistories StudentClassHistory[]
  feePayments           FeePayment[]
  classFeeStructures    ClassFeeStructure[]
  subscriptionPayments  SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

model SubscriptionPayment {
  id            Int                       @id @default(autoincrement())
  schoolId      Int
  school        School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  amount        Decimal                   @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  status        SubscriptionPaymentStatus @default(PAID)
  transactionId String?
  invoiceNo     String?                   @unique
  note          String?
  paidAt        DateTime                  @default(now())
  createdAt     DateTime                  @default(now())

  @@index([schoolId])
  @@index([status])
  @@index([paidAt])
}

model HomeSlider {
  id       Int     @id @default(autoincrement())
  schoolId Int
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  imageUrl String
  title    String?
  order    Int     @default(0)
  isActive Boolean @default(true)

  @@index([schoolId])
  @@index([isActive])
}

// --- CORE USER MODELS ---

model Employee {
  id          String   @id
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  username    String   @unique
  password    String?
  role        UserRole @default(STAFF)
  name        String
  surname     String
  email       String?  @unique
  phone       String?  @unique
  address     String
  img         String?
  bloodType   String
  sex         UserSex
  birthday    DateTime
  designation String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjects          Subject[]
  lessons           Lesson[]
  classes           Class[]                   @relation("ClassSupervisor")
  classSubjects     ClassSubjectTeacher[]
  salaryStructures  EmployeeSalaryStructure[]
  salaryPayments    EmployeeSalaryPayment[]
  collectedFees     FeePayment[]              @relation("FeeCollector")
  processedSalaries EmployeeSalaryPayment[]   @relation("SalaryProcessor")

  @@index([schoolId])
  @@index([role])
  @@index([schoolId, role])
}

model Student {
  id        String   @id
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  username  String   @unique
  password  String?
  name      String
  surname   String
  email     String?  @unique
  phone     String?  @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  birthday  DateTime
  createdAt DateTime @default(now())

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])
  classId  Int
  class    Class   @relation(fields: [classId], references: [id])
  gradeId  Int
  grade    Grade   @relation(fields: [gradeId], references: [id])

  attendances  Attendance[]
  results      Result[]
  classHistory StudentClassHistory[]
  feePayments  FeePayment[]

  @@index([schoolId])
  @@index([classId])
  @@index([gradeId])
  @@index([schoolId, classId])
}

model Parent {
  id        String    @id
  schoolId  Int
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  username  String    @unique
  surname   String
  password  String?
  name      String
  email     String?   @unique
  phone     String    @unique
  address   String
  createdAt DateTime  @default(now())
  students  Student[]

  @@index([schoolId])
  @@index([phone])
}

// --- ACADEMIC STRUCTURE ---

model Grade {
  id           Int                   @id @default(autoincrement())
  schoolId     Int
  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  level        Int
  students     Student[]
  classes      Class[]
  classHistory StudentClassHistory[]

  @@unique([schoolId, level])
  @@index([schoolId])
}

model Class {
  id           Int       @id @default(autoincrement())
  schoolId     Int
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name         String
  capacity     Int
  supervisorId String?
  supervisor   Employee? @relation("ClassSupervisor", fields: [supervisorId], references: [id])
  gradeId      Int
  grade        Grade     @relation(fields: [gradeId], references: [id])

  lessons           Lesson[]
  students          Student[]
  events            Event[]
  announcements     Announcement[]
  subjectTeachers   ClassSubjectTeacher[]
  classHistory      StudentClassHistory[]
  feeStructures     ClassFeeStructure[]
  feePayments       FeePayment[]
  examPublish       ExamPublish[]
  assignmentPublish AssignmentPublish[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([gradeId])
  @@index([supervisorId])
}

model Subject {
  id            Int                   @id @default(autoincrement())
  schoolId      Int
  school        School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name          String
  teachers      Employee[]
  lessons       Lesson[]
  classTeachers ClassSubjectTeacher[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClassSubjectTeacher {
  id           Int      @id @default(autoincrement())
  schoolId     Int
  classId      Int
  class        Class    @relation(fields: [classId], references: [id])
  subjectId    Int
  subject      Subject  @relation(fields: [subjectId], references: [id])
  teacherId    String
  teacher      Employee @relation(fields: [teacherId], references: [id])
  lessons      Lesson[]
  academicYear String   @default("2026")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([classId, subjectId, academicYear])
  @@index([schoolId])
  @@index([classId])
  @@index([teacherId])
  @@index([academicYear])
}

// REMOVED schoolId from Lesson - accessible via Class -> School
model Lesson {
  id                    Int                 @id @default(autoincrement())
  name                  String
  day                   Day
  startTime             DateTime
  endTime               DateTime
  subjectId             Int
  subject               Subject             @relation(fields: [subjectId], references: [id])
  classId               Int
  class                 Class               @relation(fields: [classId], references: [id])
  teacherId             String
  teacher               Employee            @relation(fields: [teacherId], references: [id])
  exams                 Exam[]
  assignments           Assignment[]
  attendances           Attendance[]
  classSubjectTeacherId Int
  classSubjectTeacher   ClassSubjectTeacher @relation(fields: [classSubjectTeacherId], references: [id])
  schoolId              Int
  school                School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([day])
  @@index([schoolId])
}

// --- SALARY MANAGEMENT ---

model SalaryType {
  id          Int                       @id @default(autoincrement())
  schoolId    Int
  school      School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isRecurring Boolean                   @default(false)
  isActive    Boolean                   @default(true)
  structures  EmployeeSalaryStructure[]
  payments    EmployeeSalaryPayment[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([isActive])
}

model EmployeeSalaryStructure {
  id           Int                     @id @default(autoincrement())
  schoolId     Int
  employeeId   String
  employee     Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  salaryTypeId Int
  salaryType   SalaryType              @relation(fields: [salaryTypeId], references: [id], onDelete: Cascade)
  amount       Decimal                 @db.Decimal(10, 2)
  payments     EmployeeSalaryPayment[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([employeeId, salaryTypeId])
  @@index([schoolId])
  @@index([employeeId])
}

model EmployeeSalaryPayment {
  id                Int                      @id @default(autoincrement())
  schoolId          Int
  invoiceNumber     String                   @unique
  employeeId        String
  employee          Employee                 @relation(fields: [employeeId], references: [id])
  salaryTypeId      Int
  salaryType        SalaryType               @relation(fields: [salaryTypeId], references: [id])
  salaryStructureId Int?
  salaryStructure   EmployeeSalaryStructure? @relation(fields: [salaryStructureId], references: [id])
  amountPaid        Decimal                  @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  academicYear      String
  monthLabel        String?
  remarks           String?
  processedById     String
  processedBy       Employee                 @relation("SalaryProcessor", fields: [processedById], references: [id])
  paidAt            DateTime                 @default(now())

  @@index([schoolId])
  @@index([employeeId])
  @@index([invoiceNumber])
  @@index([paidAt])
  @@index([schoolId, academicYear])
}

// --- FEE MANAGEMENT ---

model FeeType {
  id              Int                 @id @default(autoincrement())
  schoolId        Int
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  isActive        Boolean             @default(true)
  classStructures ClassFeeStructure[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([isActive])
}

// REMOVED redundant schoolId from ClassFeeStructure (accessible via Class)
model ClassFeeStructure {
  id        Int          @id @default(autoincrement())
  classId   Int
  class     Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  feeTypeId Int
  feeType   FeeType      @relation(fields: [feeTypeId], references: [id], onDelete: Cascade)
  academicYear String
  amount    Float
  payments  FeePayment[]
  schoolId  Int
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([classId, feeTypeId, academicYear])
  @@index([classId])
  @@index([schoolId])
  @@index([academicYear])

}

// REMOVED redundant schoolId from FeePayment (accessible via Student or Class)
model FeePayment {
  id                  Int               @id @default(autoincrement())
  invoiceNumber       String            @unique
  studentId           String
  student             Student           @relation(fields: [studentId], references: [id])
  classId             Int
  class               Class             @relation(fields: [classId], references: [id])
  classFeeStructureId Int
  classFeeStructure   ClassFeeStructure @relation(fields: [classFeeStructureId], references: [id])
  amountPaid          Float
  paymentMethod       PaymentMethod
  academicYear        String
  monthLabel          String?
  remarks             String?
  collectedById       String
  collectedBy         Employee          @relation("FeeCollector", fields: [collectedById], references: [id])
  paidAt              DateTime          @default(now())
  schoolId            Int
  school              School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([classId])
  @@index([invoiceNumber])
  @@index([paidAt])
  @@index([academicYear])
  @@index([studentId, academicYear])
}

// --- SMS SYSTEM ---

model SMSLog {
  id         Int       @id @default(autoincrement())
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  receiverNo String
  message    String
  status     SMSStatus @default(PENDING)
  sentAt     DateTime  @default(now())

  @@index([schoolId])
  @@index([status])
  @@index([sentAt])
}

// --- ACADEMIC RECORDS ---

// REMOVED redundant schoolId from StudentClassHistory (accessible via Student)
model StudentClassHistory {
  id           Int      @id @default(autoincrement())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  classId      Int
  class        Class    @relation(fields: [classId], references: [id])
  gradeId      Int
  grade        Grade    @relation(fields: [gradeId], references: [id])
  academicYear String
  rollNumber   Int
  promotedAt   DateTime @default(now())
  schoolId     Int
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYear])
  @@index([studentId])
  @@index([classId])
  @@index([academicYear])
  @@index([schoolId])
}

model Exam {
  id             Int           @id @default(autoincrement())
  title          String
  startTime      DateTime
  endTime        DateTime
  totalMarks     Int           @default(100)
  mcqScore       Int?
  writtenScore   Int?
  practicalScore Int?
  lessonId       Int
  session        Int
  lesson         Lesson        @relation(fields: [lessonId], references: [id])
  results        Result[]
  examPublish    ExamPublish[]
  schoolId       Int // ← যোগ করো
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([schoolId])
}

// REMOVED redundant schoolId from ExamPublish (accessible via Class)
model ExamPublish {
  id          Int     @id @default(autoincrement())
  examId      Int     @unique
  exam        Exam    @relation(fields: [examId], references: [id])
  classId     Int
  class       Class   @relation(fields: [classId], references: [id])
  session     String
  isPublished Boolean @default(false)
  publishedAt DateTime? 
  schoolId    Int // ← যোগ করো
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([isPublished])
  @@index([schoolId])
}

model Assignment {
  id                Int                @id @default(autoincrement())
  title             String
  dueDate           DateTime
  lessonId          Int
  lesson            Lesson             @relation(fields: [lessonId], references: [id])
  results           Result[]
  assignmentPublish AssignmentPublish?
  schoolId          Int
  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([dueDate])
  @@index([schoolId])
}

// REMOVED redundant schoolId from AssignmentPublish (accessible via Class)
model AssignmentPublish {
  id           Int        @id @default(autoincrement())
  assignmentId Int        @unique
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  classId      Int
  class        Class      @relation(fields: [classId], references: [id])
  session      String
  isPublished  Boolean    @default(false)
  publishedAt DateTime? 
  schoolId     Int
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([isPublished])
  @@index([schoolId])
}

model Result {
  id             Int         @id @default(autoincrement())
  score          Int
  totalScore     Int
  mcqScore       Int? 
  writtenScore   Int? 
  grade           String?   
  remarks         String?
  practicalScore Int?
  examId         Int?
  exam           Exam?       @relation(fields: [examId], references: [id])
  assignmentId   Int?
  assignment     Assignment? @relation(fields: [assignmentId], references: [id])
  studentId      String
  student        Student     @relation(fields: [studentId], references: [id])
  schoolId       Int 
  school         School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId]) // Prevent duplicate results for same exam
  @@unique([studentId, assignmentId]) // Prevent duplicate results for same assignment
  @@index([studentId])
  @@index([schoolId])
  @@index([examId])
  @@index([assignmentId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  present   Boolean
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  lessonId  Int?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id])
  schoolId  Int? // ← যোগ করো
  school    School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([date, studentId])
  @@index([schoolId, date])
  @@index([studentId])
  @@index([date])
  @@index([lessonId])
  @@index([date, studentId])
}

// --- COMMUNICATION ---

model Event {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
  isPublic    Boolean  @default(true)

  @@index([schoolId])
  @@index([classId])
  @@index([startTime])
  @@index([isPublic])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String
  date        DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
  isPublic    Boolean  @default(true)

  @@index([schoolId])
  @@index([classId])
  @@index([date])
  @@index([isPublic])
}
